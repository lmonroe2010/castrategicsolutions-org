---
// Single-page marketing site. Section order matches App.jsx in the handoff:
// Hero → DataStrip → About → DeployFunds → Grants → RobinHood → Team.
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Hero from '../components/Hero.astro';
import DataStrip from '../components/DataStrip.astro';
import About from '../components/About.astro';
import DeployFunds from '../components/DeployFunds.astro';
import Grants from '../components/Grants.astro';
import RobinHoodCallout from '../components/RobinHoodCallout.astro';
import Team from '../components/Team.astro';
---
<Base>
  <SiteHeader />
  <main>
    <Hero />
    <DataStrip />
    <About />
    <DeployFunds />
    <Grants />
    <RobinHoodCallout />
    <Team />
  </main>
  <SiteFooter />
</Base>
