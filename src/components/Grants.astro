---
// "Our Grants" — Variant A (Ledger). Q3 2026 is open for applications; Q2 and
// Q1 show below as closed/awarded ledgers. When Q3 grants are assigned, add a
// Q3_GRANTS array above Q2_GRANTS and promote it to a live ledger block.
const Q2_GRANTS = [
  {
    amount: '$30,000',
    name: 'TLC Child & Family Services',
    desc: "Earmarked specifically for partnership housing projects. TLC partners with landlords and homeowners to place foster and former-foster youth and young adults ages 16–24 into safe apartments, granny units, and homes across Sonoma County — pairing each placement with mobile case management, life skills, and long-term support.",
    tags: ['housing', 'partnership', 'youth'],
  },
  {
    amount: '$7,500',
    name: "Children's Museum of Sonoma County",
    desc: "Funding 2027 summer camp scholarships, ensuring children from low-income families in West County have access to the Museum's Wonder Camp program — nature-based, hands-on learning for ages 6–12.",
    tags: ['education', 'children', 'west-county'],
  },
  {
    amount: '$7,500',
    name: 'Community Support Network',
    desc: "Supporting CSN's supportive-housing network for people experiencing homelessness alongside mental-health and behavioral-health challenges. Across nine Sonoma County homes — from the Opportunity House shelter to permanent supportive housing — CSN houses more than 200 residents each year, pairing stable shelter with the care that keeps them housed.",
    tags: ['housing', 'behavioral-health', 'santa-rosa'],
  },
  {
    amount: '$7,500',
    name: 'The Living Room',
    desc: "Directed to The Living Room, the only daytime drop-in center in Sonoma County serving women and children experiencing or at risk of homelessness. Since 1993, its Women's and Mother & Child programs have provided meals, transitional housing, and a path to stability — and it is SSI's frontline operating partner at Giffen House.",
    tags: ['housing', 'women-children', 'santa-rosa'],
  },
  {
    amount: '$7,500',
    name: 'Sebastopol Inter-Church Food Pantry',
    desc: "A collaborative ministry of Sebastopol churches based at St. Stephen's Episcopal, providing groceries and food staples to West County residents — Sebastopol, Graton, Occidental, Bodega, Freestone, and Forestville — several days a week.",
    tags: ['food-security', 'west-county', 'sebastopol'],
  },
  {
    amount: '$5,000',
    name: 'Redwood Empire Food Bank',
    desc: "Supporting hunger relief across Sonoma County and Northern California. REFB is the region's largest food assistance organization, serving over 135,000 individuals annually through 300+ distributions and 130 community partnerships.",
    tags: ['food-security'],
  },
  {
    amount: '$5,000',
    name: 'Sonoma County Acts of Kindness',
    desc: "All-volunteer 501(c)3 founded by a formerly unhoused Santa Rosa resident — one of the largest mutual aid networks in the Bay Area, providing meals, supplies, and advocacy for unsheltered Sonoma County residents seven days a week.",
    tags: ['food-security', 'advocacy'],
  },
  {
    amount: '$5,000',
    name: "St. Mary's College of CA — DIRT Program",
    desc: "A student scholarship for the DIRT program (Dismantle, Immerse, Reflect, Transform) — a signature Jan Term course at St. Mary's that sends students into impoverished communities to do hands-on service work, while challenging them to think systemically about the root causes of poverty and inequality.",
    tags: ['education', 'scholarship'],
  },
];

const Q1_GRANTS = [
  {
    amount: '$15,000',
    name: 'The Healthy Room Project',
    desc: "Seed funding to open the inaugural Sonoma County branch, concentrating on Zone 4 (unincorporated West County). One-day bedroom makeovers — clean rooms, beds, desks, lighting — for children ages 5–16 living in unhealthy conditions.",
    tags: ['housing', 'children', 'west-county'],
  },
  {
    amount: '$15,000',
    name: 'TLC Child & Family Services',
    desc: "Earmarked for TLC's young adult transitional housing program, serving foster youth aging out of foster care and other at-risk youth ages 16–25. Housing, job training, and life-skills support around Santa Rosa Junior College.",
    tags: ['housing', 'transitional', 'youth'],
  },
  {
    amount: '$5,000',
    name: "Children's Museum of Sonoma County",
    desc: "Scholarships for children from rural West County to attend the Museum's full-time summer camp — allowing working parents to continue employment while children are in enriching, safe summer programs.",
    tags: ['education', 'children', 'rural'],
  },
  {
    amount: '$5,000',
    name: 'Redwood Empire Food Bank',
    desc: "Supporting food insecurity relief across Sonoma County. REFB is the region's largest hunger-relief organization, serving over 135,000 individuals annually across five counties.",
    tags: ['food-security'],
  },
  {
    amount: '$5,000',
    name: 'Sonoma County Acts of Kindness',
    desc: "All-volunteer 501(c)3 founded by a formerly unhoused Santa Rosa resident — one of the largest mutual aid networks in the Bay Area, providing meals, supplies, and advocacy for unsheltered Sonoma County residents seven days a week.",
    tags: ['food-security', 'advocacy'],
  },
  {
    amount: '$5,000',
    name: 'shARK Education Foundation',
    desc: "Discretionary fund for teachers at Harmony Elementary and Salmon Creek Middle School (Occidental, CA) — classroom supplies, field trips, and books to enrich the experience for rural West County students.",
    tags: ['education', 'rural', 'west-county'],
  },
];

const Q2_TOTALS = {
  assigned: '$75,000',
  remaining: '$0',
  cycleSize: '$75,000',
};
---
<section class="section paper" id="grants">
  <div class="container">
    <div class="opener">
      <div class="eyebrow">Q3 2026 Grant Cycle · Now Open</div>
      <h2>Our Grants</h2>
      <p class="lead">Applications for the <strong style="color: var(--ink-700); font-weight: 600;">Q3 2026</strong> community-grant cycle are now open. We fund Sonoma County nonprofits working on housing, affordability, food security, and education — with priority given to rural and unincorporated West County organizations.</p>
      <a class="btn btn-primary" href="mailto:Luke@CaStrategicSolutions.org?subject=Q3%202026%20Grant%20Application">Apply for a Grant</a>
    </div>

    <div class="grants-divider">
      <span>Q2 2026 · Closed Cycle</span>
    </div>

    <div class="grants-a historical">
      {Q2_GRANTS.map((g) => (
        <div class="row">
          <div class="amount">{g.amount}</div>
          <div>
            <h4>{g.name}</h4>
            <p>{g.desc}</p>
          </div>
          <div class="tags">
            {g.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
      <div class="foot">
        <div class="amount">{Q2_TOTALS.assigned}</div>
        <div class="lbl">Q2 2026 Awarded</div>
        <div class="meta">Eight organizations · Closed cycle</div>
      </div>
    </div>

    <div class="grants-divider">
      <span>Q1 2026 · Inaugural Cycle</span>
    </div>

    <div class="grants-a historical">
      {Q1_GRANTS.map((g) => (
        <div class="row">
          <div class="amount">{g.amount}</div>
          <div>
            <h4>{g.name}</h4>
            <p>{g.desc}</p>
          </div>
          <div class="tags">
            {g.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
      <div class="foot">
        <div class="amount">$50,000</div>
        <div class="lbl">Q1 2026 Awarded</div>
        <div class="meta">Six organizations · Closed cycle</div>
      </div>
    </div>
  </div>
</section>
