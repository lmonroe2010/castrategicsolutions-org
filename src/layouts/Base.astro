---
// Strategic Solutions, Inc. — base HTML shell.
// Single-page marketing site; this layout is shared by index.astro and any
// future marketing pages so head/meta/analytics stay consistent.
export interface Props {
  title?: string;
  description?: string;
  /** Absolute URL of the current page, used for canonical + og:url. */
  url?: string;
}

const {
  title = 'Strategic Solutions, Inc. — Housing Progress Through Innovation',
  description = "A California nonprofit applying business-minded strategy to West Sonoma County's housing crisis through community grants, affordable housing investment, and a free grant-writing service for local nonprofits.",
  url = 'https://castrategicsolutions.org/',
} = Astro.props;

import '../styles/colors_and_type.css';
import '../styles/styles.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#1B3A6B" />
  <link rel="canonical" href={url} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />

  <!-- Open Graph (Facebook, LinkedIn) -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content="A California nonprofit applying business-minded strategy to West Sonoma County's housing crisis." />
  <meta property="og:image" content="https://castrategicsolutions.org/assets/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Strategic Solutions, Inc." />
  <meta name="twitter:description" content="Housing progress through innovation in West Sonoma County." />
  <meta name="twitter:image" content="https://castrategicsolutions.org/assets/og-image.png" />

  <!-- Google Analytics 4 -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-GMN20VGKM7"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-GMN20VGKM7', { anonymize_ip: true });
  </script>
</head>
<body>
  <slot />
</body>
</html>
